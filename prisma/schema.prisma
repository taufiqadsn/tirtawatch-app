// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  extensions = [postgis]
}

model User {
  id String @id @default(uuid())
  full_name String
  email String
  password_hash String
  role ROLE @default(CITIZEN)
  reports Report[]
  created_at DateTime @default(now())
  status_histories StatusHistory[]
}

model Report {
  id String @id @default(uuid())
  reporter_id String
  category_id Int
  description String
  photo_url String
  latitude Decimal
  longitude Decimal
  address_name String
  status Status @default(NEW)
  created_at DateTime @default(now())
  status_histories StatusHistory[]

  reporter User @relation(fields: [reporter_id], references: [id])
}

model StatusHistory {
  id              String   @id @default(uuid())
  report_id       String
  changed_by      String
  old_status      Status
  new_status      Status
  remarks         String?  @db.Text
  proof_photo_url String?
  created_at      DateTime @default(now())

  report          Report   @relation(fields: [report_id], references: [id])
  technician      User     @relation(fields: [changed_by], references: [id])
}

enum ROLE {
  CITIZEN
  ADMIN
  TECHNICIAN
}

enum Status {
  NEW
  IN_PROGRESS
  RESOLVED
}